{
  "compilerOptions": {
    "target": "es6",                // Modern JS, compatible with Cypress
    "module": "commonjs",           // Standard for Node.js projects
    "types": ["cypress"],           // ✅ Add Cypress types
    "strict": true,                 // Keep strict type checking
    "esModuleInterop": true,        // Allow import/export compatibility
    "skipLibCheck": true            // Skip library checks for faster builds
  },
  "include": [
    "cypress/**/*.ts"               // Tell TS to check Cypress test files
  ]
}
